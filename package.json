{
  "name": "@kevincojean/opencode-tmuxwindowrenaming",
  "version": "1.1.1",
  "description": "Updates tmux window name based on OpenCode session",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "watch": "tsc -p tsconfig.build.json --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tmux"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kevincojean/opencode-tmuxwindowrenaming"
  }
}
